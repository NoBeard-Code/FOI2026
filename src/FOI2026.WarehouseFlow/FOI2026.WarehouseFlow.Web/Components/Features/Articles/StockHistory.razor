@page "/articles/{id:int}/stock-history"
@rendermode InteractiveServer

@using FOI2026.WarehouseFlow.Infrastructure.Data.Models
@using FOI2026.WarehouseFlow.Services.Services
@using FOI2026.WarehouseFlow.Services.Models
@using Microsoft.AspNetCore.Authorization
@using FOI2026.WarehouseFlow.Services

@inject NavigationManager NavigationManager
@inject ArticleService ArticleService
@inject StockHistoryService StockHistoryService

@attribute [Authorize]

<PageTitle>Povijest promjena zaliha</PageTitle>

<h1>Povijest promjena zaliha</h1>

<a href="/articles" class="back-link">&#8249; Povratak na artikle</a>

@if (article == null || history == null)
{
    <p><em>Učitavanje...</em></p>
}
else
{
    <div class="article-info mb-4">
        <p><strong>Artikl :</strong> @article.Name</p>
        <p><strong>Šifra artikla:</strong> @article.Code</p>
    </div>

    @if (!history.Any())
    {
        <p>Nema zabilježenih promjena za ovaj artikl.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Datum i vrijeme</th>
                    <th>Korisnik</th>
                    <th>Vrsta promjene</th>
                    <th>Količina</th>
                    <th>Novo stanje</th>
                    @if (showNotes)
                    {
                        <th>Napomena</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in history)
                {
                    <tr>
                        <td>
                            <div>@entry.Date.ToString("dd.MM.yyyy")</div>
                            <small class="text-muted">@entry.Date.ToString("HH:mm")</small>
                        </td>
                        <td>@entry.UserFullName</td>
                        <td>@(entry.ChangeTypeName ?? (entry.ChangeType == "+" ? "Dodavanje" : "Otpis"))</td>
                        <td>
                            @if (entry.ChangeType == "+")
                            {
                                <span class="text-success fw-bold">+@entry.Quantity</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">-@entry.Quantity</span>
                            }
                        </td>
                        <td>@entry.NewStock</td>
                        @if (showNotes)
                        {
                            <td>
                                @if (!string.IsNullOrWhiteSpace(entry.Note))
                                {
                                    <span class="badge bg-secondary">@entry.Note</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter]
    public int id { get; set; }

    private Article? article;
    private IEnumerable<StockHistoryEntry>? history;
    private bool showNotes = false;

    protected override async Task OnInitializedAsync()
    {
        article = await ArticleService.GetArticleByIdAsync(id);

        if (article == null)
        {
            NavigationManager.NavigateTo("/articles");
            return;
        }

        var entries = await StockHistoryService.GetStockHistoryAsync(id);
        history = entries.ToList();

        showNotes = history.Any(e => !string.IsNullOrWhiteSpace(e.Note));
    }
}

<style>
    h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: #555;
        text-decoration: none;
        font-size: 0.95rem;
    }

        .back-link:hover {
            color: #000;
        }

    .article-info p {
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
        color: #444;
    }
</style>