@page "/suppliers/add"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="container">
    <div class="d-flex align-items-center mb-3">
        <a href="/suppliers" class="btn btn-link ps-0">
            <i class="bi bi-arrow-left"></i> Povratak
        </a>
    </div>

    <h3>Dodavanje dobavljača</h3>

    <div class="card mt-3">
        <div class="card-body">

            <div class="mb-3">
                <label>Naziv</label>
                <input class="form-control" @bind="name" />
            </div>

            <div class="mb-3">
                <label>OIB</label>
                <input class="form-control" @bind="oib" />
            </div>

            <div class="mb-3">
                <label>Adresa</label>
                <input class="form-control" @bind="address" />
            </div>

            <div class="mb-3">
                <label>Kontakt</label>
                <input class="form-control" @bind="contact" />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <input class="form-control" @bind="email" />
            </div>

            <div class="d-flex justify-content-end">
                <button class="btn btn-primary" @onclick="Spremi">Spremi</button>
            </div>

            @if (!string.IsNullOrEmpty(greska))
            {
                <div class="alert alert-danger mt-3">@greska</div>
            }

            @if (uspjeh)
            {
                <div class="alert alert-success mt-3">Dobavljač uspješno dodan.</div>
            }

        </div>
    </div>
</div>