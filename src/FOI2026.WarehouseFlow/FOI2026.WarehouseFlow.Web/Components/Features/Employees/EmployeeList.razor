@page "/employees"
@rendermode InteractiveServer
@using FOI2026.WarehouseFlow.Infrastructure.Data.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Popis zaposlenika</h3>
        <button class="btn btn-primary" @onclick="DodajZaposlenika">
            <i class="bi bi-plus-lg"></i> Dodaj zaposlenika
        </button>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(aktivniTab == "svi" ? "active" : "")"
               @onclick='() => PromijeniTab("svi")' style="cursor:pointer">Svi</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(aktivniTab == "aktivni" ? "active" : "")"
               @onclick='() => PromijeniTab("aktivni")' style="cursor:pointer">Aktivni</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(aktivniTab == "deaktivirani" ? "active" : "")"
               @onclick='() => PromijeniTab("deaktivirani")' style="cursor:pointer">Deaktivirani</a>
        </li>
    </ul>

    @if (zaposlenici == null)
    {
        <p>Učitavanje...</p>
    }
    else if (!zaposlenici.Any())
    {
        <p>Nema zaposlenika.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Ime i prezime</th>
                    <th>Korisničko ime</th>
                    <th>Email</th>
                    <th>Uloga</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var zaposlenik in ZaposleniziNaTrenutnoStranici)
                {
                    <tr>
                        <td>@zaposlenik.User.FirstName @zaposlenik.User.LastName</td>
                        <td>@zaposlenik.User.UserName</td>
                        <td>@zaposlenik.User.Email</td>
                        <td>@(zaposlenik.Role == "Worker" ? "Radnik" : zaposlenik.Role)</td>
                        <td>
                            @if (zaposlenik.User.IsActive)
                            {
                                <span class="badge bg-success">AKTIVAN</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">DEAKTIVIRAN</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (zaposlenik.User.IsActive)
                                {
                                    <button class="btn btn-sm btn-warning"
                                            @onclick="() => Deaktiviraj(zaposlenik.User.Id)">
                                        Deaktiviraj
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success"
                                            @onclick="() => Aktiviraj(zaposlenik.User.Id)">
                                        Aktiviraj
                                    </button>
                                }

                                <div class="dropdown">
                                    <button class="btn btn-sm btn-secondary"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        ...
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <button class="dropdown-item"
                                                    @onclick="() => Uredi(zaposlenik.User.Id)">
                                                <i class="bi bi-pencil"></i> Uredi
                                            </button>
                                        </li>
                                        <li>
                                            <button class="dropdown-item text-danger"
                                                    @onclick="() => Obrisi(zaposlenik.User.Id)">
                                                <i class="bi bi-trash"></i> Obriši
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (UkupnoStranica > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(trenutnaStranica == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IdiNaStranicuu(trenutnaStranica - 1)">
                            Prethodni
                        </button>
                    </li>

                    @for (int i = 1; i <= UkupnoStranica; i++)
                    {
                        var stranica = i;
                        <li class="page-item @(trenutnaStranica == stranica ? "active" : "")">
                            <button class="page-link" @onclick="() => IdiNaStranicuu(stranica)">
                                @stranica
                            </button>
                        </li>
                    }

                    <li class="page-item @(trenutnaStranica == UkupnoStranica ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IdiNaStranicuu(trenutnaStranica + 1)">
                            Sljedeći
                        </button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>