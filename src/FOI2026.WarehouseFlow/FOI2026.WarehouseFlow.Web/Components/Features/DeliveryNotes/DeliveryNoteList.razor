@page "/delivery-notes"
@rendermode InteractiveServer
@using FOI2026.WarehouseFlow.Infrastructure.Data.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<div class="container-fluid py-3">
    <div class="page-header">
        <h3>Otpremnice</h3>
        <button class="btn btn-primary" @onclick="DodajOtpremnicu">
            <i class="bi bi-plus-lg"></i> Nova otpremnica
        </button>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <input class="form-control"
                   placeholder="Pretraži otpremnice..."
                   @bind="search"
                   @bind:event="oninput" />
        </div>
    </div>

    @if (otpremnice == null)
    {
        <p>Učitavanje...</p>
    }
    else if (!FiltriraneOtpremnice.Any())
    {
        <div class="table-card p-4 text-center text-muted">
            <i class="bi bi-truck fs-1"></i>
            <p class="mt-2">Nema otpremnica.</p>
        </div>
    }
    else
    {
        <div style="background:white; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,0.08); overflow:visible;">
            <table style="width:100%; border-collapse:collapse; background:white; border-radius:10px; overflow:visible;">
                <thead style="background-color:var(--wf-navy); color:white;">
                    <tr>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Broj</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Datum</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Kupac</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Broj artikala</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Status</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var otpremnica in OtpremniceNaStranici)
                    {
                        <tr style="border-bottom:1px solid var(--wf-lightest-blue); transition:background-color 0.15s ease;"
                            onmouseover="this.style.backgroundColor='var(--wf-lightest-blue)'"
                            onmouseout="this.style.backgroundColor=''">
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">@otpremnica.Code</td>
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">@otpremnica.Date.ToString("dd/MM/yyyy")</td>
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">@otpremnica.Partner?.Name</td>
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">@(otpremnica.DeliveryNoteItems?.Count ?? 0)</td>
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">
                                <span class="badge bg-success">@otpremnica.Status</span>
                            </td>
                            <td style="padding:12px 16px; font-size:14px; vertical-align:middle; text-align:center;">
                                <div class="dropdown">
                                    <button class="btn btn-sm"
                                            style="background:transparent; border:none; font-weight:700; color:var(--wf-navy); padding:4px 8px;"
                                            data-bs-toggle="dropdown"
                                            data-bs-boundary="viewport"
                                            aria-expanded="false">
                                        ...
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                        </li>
                                        <li>
                                            <button class="dropdown-item text-danger"
                                                    @onclick="() => Obrisi(otpremnica.DeliveryNoteId)">
                                                <i class="bi bi-trash"></i> Obriši
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (UkupnoStranica > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(trenutnaStranica == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IdiNaStranicu(trenutnaStranica - 1)">
                            Prethodni
                        </button>
                    </li>

                    @for (int i = 1; i <= UkupnoStranica; i++)
                    {
                        var str = i;
                        <li class="page-item @(trenutnaStranica == str ? "active" : "")">
                            <button class="page-link" @onclick="() => IdiNaStranicu(str)">
                                @str
                            </button>
                        </li>
                    }

                    <li class="page-item @(trenutnaStranica == UkupnoStranica ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IdiNaStranicu(trenutnaStranica + 1)">
                            Sljedeći
                        </button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
