@page "/delivery-notes/add"
@rendermode InteractiveServer
@using FOI2026.WarehouseFlow.Infrastructure.Data.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<div class="container-fluid py-3">
    <div class="d-flex align-items-center mb-3">
        <a href="/delivery-notes" class="btn btn-link ps-0">
            <i class="bi bi-arrow-left"></i> Povratak
        </a>
    </div>

    <h3>Otpremnice</h3>

    <div class="form-card mt-3">
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Broj otpremnice</label>
                <input class="form-control" value="@generiraniKod" disabled />
            </div>
            <div class="col-md-6">
                <label class="form-label">Datum</label>
                <input class="form-control" type="date" @bind="datum" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Kupac</label>
            <div class="position-relative">
                <input class="form-control"
                       placeholder="Pretraži kupca..."
                       value="@partnerSearch"
                       @oninput="OnPartnerSearchChanged"
                       @onfocus="() => pokaziPartnerDropdown = true"
                       @onblur="SakriPartnerDropdown" />
                @if (pokaziPartnerDropdown && filtriraniiPartneri.Any())
                {
                    <ul class="list-group position-absolute w-100 shadow" style="z-index:2000; max-height:200px; overflow-y:auto;">
                        @foreach (var p in filtriraniiPartneri)
                        {
                            <li class="list-group-item list-group-item-action"
                                @onmousedown="() => OdaberiPartnera(p)"
                                style="cursor:pointer;">
                                @p.Name
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="status">
                <option value="">-- Odaberi status --</option>
                <option value="IZDANO">IZDANO</option>
                <option value="U PRIPREMI">U PRIPREMI</option>
                <option value="ISPORUČENO">ISPORUČENO</option>
                <option value="OTKAZANO">OTKAZANO</option>
            </select>
        </div>
        <div class="mb-3">
            <table style="width:100%; border-collapse:collapse; background:white; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
                <thead style="background-color:var(--wf-navy); color:white;">
                    <tr>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Artikl</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Količina</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;">Jedinica mjere</th>
                        <th style="padding:14px 16px; font-weight:500; font-size:13px; letter-spacing:0.5px; text-transform:uppercase; border:none;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (stavka, index) in stavke.Select((s, i) => (s, i)))
                    {
                        <tr style="border-bottom:1px solid var(--wf-lightest-blue);">
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle; position:relative; min-width:220px;">
                                <input class="form-control form-control-sm"
                                       placeholder="Pretraži artikl..."
                                       value="@stavka.ArtiklNaziv"
                                       @oninput="(e) => OnArtiklSearchChanged(e, index)"
                                       @onfocus="() => { stavka.PrikaziDropdown = true; StateHasChanged(); }"
                                       @onblur="() => SakriArtiklDropdown(index)" />
                                @if (stavka.PrikaziDropdown && stavka.FiltriraniArtikli.Any())
                                {
                                    <ul class="list-group position-absolute shadow"
                                        style="z-index:2000; max-height:180px; overflow-y:auto; width:calc(100% - 32px); left:16px; top:calc(100% - 4px);">
                                        @foreach (var a in stavka.FiltriraniArtikli)
                                        {
                                            <li class="list-group-item list-group-item-action"
                                                @onmousedown="() => OdaberiArtikl(index, a)"
                                                style="cursor:pointer;">
                                                @a.Name (@a.Code)
                                            </li>
                                        }
                                    </ul>
                                }
                            </td>
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">
                                <input class="form-control form-control-sm"
                                       type="number" min="1"
                                       @bind="stavka.Kolicina" />
                            </td>
                            <td style="padding:12px 16px; font-size:14px; color:#374151; vertical-align:middle;">@stavka.JedinicaMjere</td>
                            <td style="padding:12px 16px; font-size:14px; vertical-align:middle; text-align:center;">
                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => UkloniStavku(index)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mb-3">
            <button class="btn btn-secondary" @onclick="DodajStavku">
                <i class="bi bi-plus-lg"></i> Dodaj artikl
            </button>
        </div>

        <button class="btn btn-primary" @onclick="Spremi">Spremi otpremnicu</button>

        @if (uspjeh)
        {
            <div class="alert alert-success mt-3 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-check-lg"></i> Otpremnica uspješno upisana</span>
                <button class="btn-close" @onclick="() => uspjeh = false"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(greska))
        {
            <div class="alert alert-danger mt-3 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-x-lg"></i> @greska</span>
                <button class="btn-close" @onclick="() => greska = string.Empty"></button>
            </div>
        }
    </div>
</div>
